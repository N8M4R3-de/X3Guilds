<script>
<name>plugin.logistics.run</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Logistics: Main run script</description>
<arguments>
<argument index="1" name="a.restart" type="Var/Boolean" desc="Restart?" />
</arguments>
<sourceplaintext>
<![CDATA[
  $Guild.Data = get global variable: name='guilds.data'
  $Logistics.Data = $Guild.Data['logistics']
  if not $Logistics.Data
    $Logistics.Data = table alloc
    $Guild.Data['logistics'] = $Logistics.Data
  end
  
  $pid = $Logistics.Data['pid']
  if $pid
    if $a.restart
      kill global script: pid=$pid
    else
      do if is global script task running: pid=$pid
        return null
    end
  end
  
  $pid = get PID
  $Logistics.Data['pid'] = $pid
  
  while [TRUE]
@   = wait 30000 ms
    
    if is a new script version available
@     START [THIS] -> call script plugin.logistics.run :  Restart?=[TRUE]
      return null
    end
    
    $networks = $Logistics.Data['networks']
    if $networks
      $pids = $Logistics.Data['network.pids']
      if not $pids
        $pids = table alloc
        $Logistics.Data['network.pids'] = $pids
      end
      
      $network = get next key: table=$networks key=null
      while $network
        $network.pid = $pids[$network]
        if $network.pid
          if not is global script task running: pid=$network.pid
            remove key $network from table $pids
            $network.pid = null
          end
        end
        if not $network.pid
          $network.data = $networks[$network]
@         START [THIS] -> call script plugin.logistics.manage :  Network Data=$network.data  Pids=$pids
        end
        $network = get next key: table=$networks key=$network
      end
    end
  end
  return null
]]>
</sourceplaintext>
