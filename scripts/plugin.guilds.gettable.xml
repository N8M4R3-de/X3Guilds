<script>
<name>plugin.guilds.gettable</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Guilds: Get table columns</description>
<arguments>
<argument index="1" name="a.menu" type="Var/String" desc="MenuID" />
<argument index="2" name="a.table" type="Var/String" desc="Table" />
</arguments>
<sourceplaintext>
<![CDATA[
  $length.table = table alloc
  $name.table = table alloc
  $search.table = table alloc
  $settings.array = create new array, size=7, elements=5, [TRUE], [TRUE], [TRUE], [TRUE], [TRUE], $search.table, null
  
  * =======================
  if $a.menu == 'station.menu'
    $ret = create new array, size=2, elements='obj.name', 'obj.sector', null, null, null, null, null, null
    $length.table['obj.name'] = 300
    if $a.table == 'factories'
      $read.text = read text: page=[Page.Menus] id=9105
    else if $a.table == 'docks'
      $read.text = read text: page=[Page.Menus] id=9104
    else if $a.table == 'complex'
      $read.text = read text: page=[Page.Menus] id=9115
    end
    $name.table['obj.name'] = $read.text
    $search.table['obj.name'] = [TRUE]
    $search.table['obj.sector'] = [TRUE]
    
  * =======================
  else if $a.menu == 'ship.menu'
    $ret = create new array, size=7, elements='obj.name', 'obj.idcode', 'obj.shield', 'obj.class', 'obj.cargo', 'obj.sector', 'ship.command', null
    $read.text = read text: page=[Page.Menus] id=9102
    $name.table['obj.name'] = $read.text
    $search.table['obj.name'] = [TRUE]
    $search.table['obj.sector'] = [TRUE]
    $search.table['ship.command'] = [TRUE]
    
  * =======================
  else if $a.menu == 'station.editmenu'
    if $a.table == 'imports'
      $ret = create new array, size=5, elements='ware.name', 'station.warebar', 'ware.tc', 'ware.vol', 'ware.avgprice', 'station.logistics.minstorage', null, null
      $name.table['obj.name'] = $read.text
      $name.table['ware.name'] = 'Imports'
      $length.table['ware.name'] = 250
      $settings.array[2] = [FALSE]
    end
    
  * =======================
  else if $a.menu == 'logistics.mainmenu'
    if $a.table == 'ships'
      $ret = create new array, size=6, elements='obj.name', 'obj.idcode', 'obj.shield', 'obj.sector', 'ship.logisitics.job', 'ship.logistics.status', null, null
      $read.text = read text: page=[Page.Menus] id=9102
      $name.table['obj.name'] = $read.text
      $settings.array[4] = [FALSE]
      $settings.array[5] = [FALSE]
      $search.table['obj.name'] = [TRUE]
      $search.table['obj.sector'] = [TRUE]
      $search.table['ship.logistics.job'] = [TRUE]
      
    else if $a.table == 'docks' OR $a.table == 'factories' OR $a.table == 'complex'
      $ret = create new array, size=5, elements='obj.name', 'obj.sector', 'station.logistics.import', 'station.logistics.export', 'station.logistics.prio', null, null, null
      if $a.table == 'docks'
        $read.text = read text: page=[Page.Menus] id=9104
      else if $a.table == 'factories'
        $read.text = read text: page=[Page.Menus] id=9105
      else if $a.table == 'complex'
        $read.text = read text: page=[Page.Menus] id=9115
      else
        $read.text = read text: page=[Page.Menus] id=9103
      end
      $name.table['obj.name'] = $read.text
      $settings.array[4] = [FALSE]
      $settings.array[5] = [FALSE]
      $search.table['obj.name'] = [TRUE]
      $search.table['obj.sector'] = [TRUE]
    end
    
  * =======================
  end
  
  if $ret
    if size of array $ret
      $ret = create new array, arguments=$ret, $name.table, $length.table, $settings.array, null
      return $ret
    end
  end
  return null
]]>
</sourceplaintext>
