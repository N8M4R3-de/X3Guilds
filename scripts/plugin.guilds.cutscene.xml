<sourceplaintext>
<![CDATA[
  if $a.cutscene == 'lc.7.4.2'
@   = wait 9000 ms
    $missile.delay = $a.value1 -> get fire missile time difference in seconds
    = $a.value1 -> add 20 units of Shadow Missile
    $a.value1 ->set fire missile time difference to 0 ms
    = $a.value1 -> fire missile Shadow Missile on $a.value2
    = $a.value1 -> fire missile Shadow Missile on $a.value2
@   = wait 500 ms
    = $a.value1 -> fire missile Shadow Missile on $a.value2
    = $a.value1 -> fire missile Shadow Missile on $a.value2
@   = wait 500 ms
    = $a.value1 -> fire missile Shadow Missile on $a.value2
    = $a.value1 -> fire missile Shadow Missile on $a.value2
@   = wait 500 ms
    = $a.value1 -> fire missile Shadow Missile on $a.value2
    = $a.value1 -> fire missile Shadow Missile on $a.value2
    $a.value1 ->set fire missile time difference to $missile.delay ms
  end
  return null
]]>
</sourceplaintext>
