<script>
<name>plugin.guilds.createtask</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Guilds: Add a new task for a guild</description>
<arguments>
<argument index="1" name="a.guild" type="Var/String" desc="Guild" />
<argument index="2" name="a.sector" type="Var/Sector" desc="Sector" />
<argument index="3" name="a.type" type="Var/String" desc="Type" />
<argument index="4" name="a.text" type="Var/String" desc="Text" />
<argument index="5" name="a.run" type="Value" desc="Run" />
<argument index="6" name="a.reward" type="Value" desc="Reword" />
<argument index="7" name="a.xp" type="Var/Number" desc="XP" />
<argument index="8" name="a.level" type="Var/Number" desc="Level" />
<argument index="9" name="a.extraData" type="Value" desc="Extra Data" />
</arguments>
<sourceplaintext>
<![CDATA[
  $Guilds.Data = get global variable: name='guilds.data'
  skip if $Guilds.Data
    return null
  
  $table.guild = $Guilds.Data[$a.guild]
  skip if $table.guild
    return null
  
  $table.tasks = $Guilds.Data['tasks']
  if not $table.tasks
    $table.tasks = table alloc
    $Guilds.Data['tasks'] = $table.tasks
  end
  
  $last.task = $Guilds.Data['last.task']
  skip if $last.task
    $last.task = 0
  inc $last.task = 
  
  do if $last.task > 2000000000
    $last.task = 1
  
  $array = create new array, size=11, elements=$a.guild, $last.task, $a.text, $a.sector, $a.type, $a.run, 'created', $a.reward
  $array[8] = $a.xp
  $array[9] = $a.level
  $array[10] = $a.extraData
  $Guilds.Data['last.task'] = $last.task
  $table.tasks[$last.task] = $array
  
  return null
]]>
</sourceplaintext>
