<script>
<name>plugin.guilds.dotask</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Guilds: Do Task (Callback from MD)</description>
<arguments>
<argument index="1" name="a.task" type="Var/Number" desc="TaskID" />
<argument index="2" name="a.event" type="Var/String" desc="Events" />
<argument index="3" name="a.param1" type="Value" desc="Param1" />
<argument index="4" name="a.param2" type="Value" desc="Param2" />
<argument index="5" name="a.background" type="Var/Boolean" desc="Background?" />
</arguments>
<sourceplaintext>
<![CDATA[
  $Guilds.Data = get global variable: name='guilds.data'
  if $Guilds.Data
    $table.tasks = $Guilds.Data['tasks']
    if $table.tasks
      $task.data = $table.tasks[$a.task]
      if $task.data
        if $a.event == 'start'
          if not $a.background
            $task.data[5] = 'started'
@           START [THIS] -> call script plugin.guilds.dotask :  TaskID=$a.task  Events=$a.event  Param1=$a.param1  Param2=$a.param2  Background?=[TRUE]
            return null
          end
          
          $sector = $task.data[3]
          $guild = $task.data[0]
          $event = $task.data[4][1]
          
          send script event: name=$event, object=$sector, param1='create', param2=$a.task
@         = wait 100 ms
          $data = $task.data[2][0]
          send script event: name=$event, object=$sector, param1='TitleID', param2=$data
          $data = $task.data[2][1]
          send script event: name=$event, object=$sector, param1='TextID', param2=$data
          $data = $task.data[6][0]
          send script event: name=$event, object=$sector, param1='Level', param2=$data
          $data = $task.data[6][1]
          send script event: name=$event, object=$sector, param1='Difficulty', param2=$data
          $data = $task.data[7]['money']
          send script event: name=$event, object=$sector, param1='Reward', param2=$data
@         = wait 100 ms
          $event = sprintf: fmt='%s.start', $event, null, null, null, null
          send script event: name=$event, object=$sector, param1=$a.task, param2=null
          
        else if $a.event == 'briefing'
          START [PLAYERSHIP] ->open menu script: script=plugin.guilds.taskmenu, value=$a.task
          
        else if $a.event == 'complete'
          $task.data[5] = 'complete'
          $data = $task.data[7]['xp']
          if $data > 0
            $guild = $task.data[0]
@           = [THIS] -> call script plugin.guilds.doexp :  Exp=$data  Guild=$guild  Delay=2000
          end
          remove key $a.task from table $table.tasks
          
        else if $a.event == 'abort'
          $task.data[5] = 'abort'
          remove key $a.task from table $table.tasks
          
        else if $a.event == 'failed'
          $task.data[5] = 'failed'
          remove key $a.task from table $table.tasks
        end
      end
    end
  end
  return null
]]>
</sourceplaintext>
