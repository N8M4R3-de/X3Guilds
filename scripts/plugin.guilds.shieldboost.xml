<script>
<name>plugin.guilds.shieldboost</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Guilds: Shield Booster Activate</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  $page.id = get global variable: name='pageid.guilds'
  $time = playing time
  [THIS] ->set local variable: name='guilds.shield.boost' value=$time
  [THIS] ->set local variable: name='guilds.shield.core' value=null
  
  $MAX = 30
  $done = 0
  
  $max.shield = [THIS] -> get maximum shield strength
  $shield.boost = $max.shield / 10
  
  while $done < $MAX
    inc $done = 
    $read.text = read text: page=$page.id id=4191
    $str = sprintf: fmt='%s  >', $read.text, null, null, null, null
    $i = 0
    while $i < $done
      $str = $str + '-'
      inc $i = 
    end
    $str = $str + '|'
    while $i < $MAX
      $str = $str + '-'
      inc $i = 
    end
    $str = $str + '<'
    
    display notification: message=$str, icon=108
@   = wait 150 ms
    play sample 962
    $shield = [THIS] -> get current shield strength
    $shield = $shield + $shield.boost
    do if $shield > $max.shield
      $shield = $max.shield
    [THIS] ->set current shield strength to $shield
  end
  
  display notification: message=' ', icon=0
  [THIS] ->set local variable: name='guilds.shield.boost' value=null
  return null
]]>
</sourceplaintext>
