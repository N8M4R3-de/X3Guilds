<script>
<name>plugin.logistics.findship</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Logistics Network</description>
<arguments>
<argument index="1" name="a.using" type="Value" desc="Using" />
<argument index="2" name="a.ships" type="Value" desc="Ships" />
<argument index="3" name="a.exclude" type="Value" desc="Exclude" />
</arguments>
<sourceplaintext>
<![CDATA[
  skip if $a.ships
    return null
  
  $jd = 2
  while $jd
    dec $jd = 
    
    $sorted = table alloc
    $key = get next key: table=$a.ships key=null
    while $key
      if $key -> exists
        $can.jump = 0
        if $key -> is autojump activated
          if $key -> get amount of ware Jumpdrive in cargo bay
            if $key -> get amount of ware Navigation Command Software MK1 in cargo bay
              $can.jump = 1
            end
          else if $key -> get amount of ware Advanced Jumpdrive in cargo bay
            $can.jump = 1
          end
        end
        
        if $can.jump == $jd
          $speed = $key -> get max speed
          $sorted[$key] = $speed
        end
      end
      $key = get next key: table=$a.ships key=$key
    end
    
    $array = sort table keys by value: table=$sorted
    $i = size of array $array
    while $i
      dec $i = 
      $ship = $array[$i]
      
      if $a.using
        do if $a.using[$ship]
          continue
      end
      
      if $a.exclude
        do if $a.exclude[$ship]
          continue
      end
      return $ship
    end
  end
  
  return null
]]>
</sourceplaintext>
