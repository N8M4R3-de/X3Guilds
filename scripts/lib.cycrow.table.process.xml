<script>
<name>lib.cycrow.table.process</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Library: Process some menu inputs for tables</description>
<arguments>
<argument index="1" name="a.obj" type="Value" desc="Object" />
<argument index="2" name="a.event" type="Value" desc="Event" />
<argument index="3" name="a.data" type="Value" desc="Data" />
<argument index="4" name="a.tableData" type="Value" desc="Table Data" />
<argument index="5" name="a.sortData" type="Value" desc="Sort Data" />
</arguments>
<sourceplaintext>
<![CDATA[
  if $a.event == [MEvent.HeadingClick]
    if $a.tableData[1]
      $menu.id = $a.data[0]
      $selection = $a.data[1]
      $value = $a.data[2]
      $var = sprintf: fmt='sort.%s.%s', $menu.id, $selection, null, null, null
      $var.dir = sprintf: fmt='sortdir.%s.%s', $menu.id, $selection, null, null, null
      
      $headings = $a.tableData[4]
      $gap = $a.tableData[2]
      
      $size = size of array $headings
      $pos = 0
      $i = 0
      while $i < $size
        $heading.len = $headings[$i]
        inc $i = 
        $heading.name = $headings[$i]
        inc $i = 
        $heading.sort = $headings[$i]
        inc $i = 
        inc $i = 
        
        $pos = $pos + $heading.len
        if $value <= $pos OR $heading.len < 0
          if $heading.sort
            $previous.sort = $a.sortData[$var]
            $tmp = $i / 4
            $a.sortData[$var] = $tmp
            if $previous.sort == $tmp
              if $a.sortData[$var.dir]
                $a.sortData[$var.dir] = 0
              else
                $a.sortData[$var.dir] = 1
              end
            else
              $a.sortData[$var.dir] = 0
            end
          end
          play sample [Sound.Success]
          return [TRUE]
        end
        $pos = $pos + $gap
      end
    end
    
    
  else if $a.event == [MEvent.Hotkey]
    $selection = $a.data[1]
    if $selection == 'info'
      $value = $a.data[2]
      if is datatype[ $value ] == DATATYPE_ARRAY
        $value = $value[1]
      end
      gosub sub.GetInfoMenu
      do if $ret
        return $ret
    end
    
    
  else if $a.event == [MEvent.Context]
    $selection = $a.data[2]
    $value = $a.data[1]
    if $selection == 'info' OR $selection == 'station.info' OR $selection == 'ship.info'
      gosub sub.GetInfoMenu
      do if $ret
        return $ret
    end
    
  else if $a.event == [MEvent.Search]
    if $a.sortData
      if $a.tableData[1]
        $search.table = $a.tableData[9]
        if $search.table
          if size of table $search.table
            $menu.id = $a.data[0]
            $value = $a.data[1]
            $var = sprintf: fmt='search.%s', $menu.id, null, null, null, null
            if not $value
              remove key $var from table $a.sortData
            else if not is datatype[ $value ] == DATATYPE_STRING
              remove key $var from table $a.sortData
            else if not get length of string $value
              remove key $var from table $a.sortData
            else
              $a.sortData[$var] = $value
            end
            return [TRUE]
          end
        end
      end
    end
  end
  
  
  return [FALSE]
  
  
  sub.GetInfoMenu:
  $ret = null
  if is datatype[ $value ] == DATATYPE_WARE
    $ret = create input: id='show.info' encyclopedia page, ware=$value
  else if $value -> exists
    $ret = create input: id='show.info' object info page, object=$value
  end
  endsub
  return null
]]>
