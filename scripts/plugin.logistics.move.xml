<script>
<name>plugin.logistics.move</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Logistics Network: Move the ship</description>
<arguments>
<argument index="1" name="a.dest" type="Var/Station" desc="Destination" />
<argument index="2" name="a.status" type="Var/Number" desc="Status" />
<argument index="3" name="a.ware" type="Var/Ware" desc="Ware" />
</arguments>
<sourceplaintext>
<![CDATA[
  [THIS] ->set command: COMMAND_LOGISTICS_NETWORK  target=null target2=null par1=null par2=null
  [THIS] ->set destination to $a.dest
  
  $ret = null
  if not [THIS] -> get amount of ware Advanced Jumpdrive in cargo bay
    if not [THIS] -> get amount of ware Jumpdrive Energy Generator in cargo bay
@     $ret = [THIS] -> call script !lib.move.resupply.energy :  Ignore AutoJump=[FALSE]  Target=$a.dest
    end
  end
  
  $page.id = get global variable: name='pageid.guilds'
  
  if $a.status == 0 OR $a.status == 1
    $status = sprintf: pageid=$page.id textid=4241, $a.ware, null, null, null, null
  else if $a.status == 2
    $status = sprintf: pageid=$page.id textid=4242, $a.ware, null, null, null, null
  else if $a.status == 3 OR $a.status == 4
    $status = sprintf: pageid=$page.id textid=4243, $a.ware, null, null, null, null
  else if $a.status == 5
    $status = sprintf: pageid=$page.id textid=4244, $a.ware, null, null, null, null
  else
    $status = null
  end
  [THIS] ->set command extra display override: text=$status
  
  while $ret != FLRET_NOPATH
@   $ret = [THIS] -> call script !move.movetostation :  station=$a.dest
    do if [DOCKEDAT] != $a.dest
      break
@   = wait 500 ms
  end
  return null
]]>
</sourceplaintext>
