<script>
<name>plugin.guilds.shieldboost.check</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Guilds: Shield Core Install</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  $page.id = get global variable: name='pageid.guilds'
  
  while [THIS] -> get amount of ware Shield Booster in cargo bay
    
    if not [THIS] -> get amount of ware Shield Booster Core in cargo bay
@     = wait 20000 ms
    else if [THIS] -> get local variable: name='guilds.shield.core'
@     = wait 20000 ms
    else
@     = wait 2000 ms
      
      if $last.docked
        if [DOCKEDAT] != $last.docked
          $last.docked = null
        end
      end
      
      if [DOCKEDAT] AND ! $last.docked
@       = wait randomly from 1500 to 3000 ms
        if [DOCKEDAT]
          if [THIS] -> get amount of ware Shield Booster Core in cargo bay
            if not [THIS] -> get local variable: name='guilds.shield.core'
              = [THIS] -> add -1 units of Shield Booster Core
              [THIS] ->set local variable: name='guilds.shield.core' value=[TRUE]
              $last.docked = [DOCKEDAT]
              
              $read.text = read text: page=$page.id id=4194
              display notification: message=$read.text, icon=108
            end
          end
        end
      end
    end
  end
  return null
]]>
</sourceplaintext>
