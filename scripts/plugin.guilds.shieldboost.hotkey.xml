<script>
<name>plugin.guilds.shieldboost.hotkey</name>
<version>1</version>
<engineversion>73</engineversion>
<description>Guilds: Shield booster hotkey activation</description>
<arguments>
</arguments>
<sourceplaintext>
<![CDATA[
  do if [PLAYERSHIP] -> get local variable: name='guilds.shield.boost'
    return null
  
  $page.id = get global variable: name='pageid.guilds'
  
  if not [PLAYERSHIP] -> get amount of ware Shield Booster in cargo bay
    $read.text = sprintf: pageid=$page.id textid=4192, Shield Booster, null, null, null, null
    display notification: message=$read.text, icon=0
    play sample 928
    return null
  end
  
  if not [PLAYERSHIP] -> get local variable: name='guilds.shield.core'
    $read.text = sprintf: pageid=$page.id textid=4193, Shield Booster Core, null, null, null, null
    display notification: message=$read.text, icon=0
    play sample 928
    return null
  end
  
  $task = [PLAYERSHIP] -> get next available task: starting=[Task.StartCustom]
  [PLAYERSHIP] ->start task $task with script plugin.guilds.shieldboost and prio 100: arg1=null arg2=null arg3=null arg4=null arg5=null
  return null
]]>
</sourceplaintext>
